{
  "manifest_version": 2,
  "name": "Qolor: Dynamic Theme Engine",
  "short_name": "Qolor",
  "description": "A theme that let you adjust colors shades and bright for texts and panels dynamically and easily.",
  "version": "1.3",
  "developer": {
    "name": "Raphael Quintão",
    "url": "https://github.com/raphaelquintao"
  },
  "icons": {
    "250": "assets/icon.png"
  },
  "incognito": "spanning",
  "permissions": [
    "theme",
    "storage",
    "unlimitedStorage",
    "browserSettings",
    "management"
  ],
  "background": {
    "scripts": ["js/bg.js"],
    "type": "module",
    "persistent": true
  },
  "browser_action": {
    "browser_style": false,
    "default_icon": "assets/icon_colored.svg",
    "default_popup": "options.html?view=popup"
  },
  
  "sidebar_action": {
    "default_panel": "options.html?view=sidebar",
    "default_icon": "assets/icon_colored.svg",
    "browser_style": false
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "photophobia@quintao.ninja",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}